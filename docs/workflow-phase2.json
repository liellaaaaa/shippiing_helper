const task1 = agent("在 " + BACKEND_ROOT + "/models/template.py 创建 DocumentTemplate 模型。\n\n现有数据库 Base 从 " + BACKEND_ROOT + "/database.py 导入。\n\nDocumentTemplate 表字段：\n- id: Integer, primary_key, autoincrement\n- name: String(100), nullable=False\n- type: String(20), nullable=False (booking|loi|msds)\n- file_path: String(500), nullable=False\n- placeholders: JSON, default=list\n- version: Integer, default=1\n- updated_at: DateTime, default=func.now()\n\n必须：\n- from sqlalchemy import Column, Integer, String, Text, DateTime, JSON\n- from sqlalchemy.sql import func\n- from app.database import Base\n- __tablename__ = \"document_templates\"\n- 写入文件", {label: "Task1: DocumentTemplate model", phase: "Task 1-4: 基础设施层"})

const task2 = agent("在 " + BACKEND_ROOT + "/models/msds_index.py 创建 MSDSIndex 模型。\n\nMSDSIndex 表字段：\n- id: Integer, primary_key, autoincrement\n- filename: String(255), nullable=False, unique=True\n- product_name_cn: String(200)\n- product_name_en: String(200)\n- physical_form: String(100)\n- ion_type: String(50)\n- ph: String(50)\n- composition_summary: Text\n- file_path: String(500), nullable=False\n- loaded: Integer, default=0\n\n必须：\n- from sqlalchemy import Column, Integer, String, Text\n- from app.database import Base\n- __tablename__ = \"msds_indexes\"\n- 写入文件", {label: "Task1: MSDSIndex model", phase: "Task 1-4: 基础设施层"})

const task3 = agent("在 " + BACKEND_ROOT + "/services/msds_service.py 创建 MSDSService 类。\n\nMSDSService 负责：\n1. extract_text(file_path: str) -> str：从 .doc/.docx/.pdf 提取纯文本\n   - .docx 用 zipfile+ElementTree 解析 XML\n   - .doc 用 chardet 检测编码后读 binary\n   - .pdf 用 PyPDF2\n\n2. extract_composition_table(text: str) -> list[dict]：解析成分表\n   - 找含\"组分\"或\"成分\"的行，提取三列（组分、CAS NO.、含量）\n   - 返回 [{\"component\": \"...\", \"cas\": \"...\", \"percentage\": \"...\"}, ...]\n\n3. extract_physical_props(text: str) -> dict：解析理化特征\n   - 外观与性状 -> physical_form\n   - 离子型 -> ion_type\n   - PH值 -> ph\n   - 用正则匹配\n\n4. index_msds_directory(dir_path: str, db_session) -> int\n   - 扫描目录（含子目录），找所有 .doc/.docx/.pdf\n   - 提取文件名中的产品名作为 product_name_cn（去数字前缀）\n   - 对每个文件调用 extract_text + extract_physical_props\n   - 写入 msds_indexes 表（upsert by filename）\n   - 返回索引文件数量\n\n5. get_msds_by_product(product_name_cn: str, db_session) -> MSDSIndex | None\n   - 按产品名模糊搜索最匹配的一条\n\n必须：\n- import chardet, zipfile, re\n- from PyPDF2 import PdfReader\n- from app.models.msds_index import MSDSIndex\n- 使用 subprocess 读 .doc（antiword 如果可用）", {label: "Task2: MSDS service", phase: "Task 1-4: 基础设施层"})

const task4 = agent("在 " + BACKEND_ROOT + "/services/transport_service.py 创建 TransportService 类。\n\nTransportService 负责从运输鉴定报告 PDF 提取字段：\n\n1. extract_text_from_pdf(file_path: str) -> str\n   - 用 PyPDF2 读取所有页文本\n\n2. extract_fields(text: str) -> dict\n   - 中英文名：从 PDF 中匹配 \"产品名称[：:]\\s*(.+)\" 或 \"品名[：:]\\s*(.+)\"\n   - 运输鉴定编号NO.：匹配 \"编号[：:]\\s*([A-Z0-9-]+)\" 或 \"报告编号[：:]\\s*([A-Z0-9-]+)\"\n   - 样品描述：从 PDF 提取外观描述段落\n\n返回：\n{\n  product_name_cn: \"...\",\n  product_name_en: \"...\",\n  report_no: \"...\",\n  sample_description: \"...\"\n}\n\n必须：\n- from PyPDF2 import PdfReader\n- 使用正则表达式匹配关键字段", {label: "Task3: Transport service", phase: "Task 1-4: 基础设施层"})

const task5 = agent("在 " + BACKEND_ROOT + "/services/export_codes_service.py 创建 ExportCodesService 类。\n\n基于 " + PHASE2_ROOT + "/参考/02.订舱出货/2024.12.5 最新出口商品编码及报关成分.xlsx\n\nExportCodesService 负责：\n1. load_export_codes(file_path: str) -> dict：懒加载整个 xlsx 到内存缓存\n   - 用 openpyxl 读取\n   - 关键列：B=商品编号(internal_code), D=商品名, F=出口商品编号(HS), 报关名称, 成分\n\n2. find_by_internal_code(internal_code: str) -> dict | None\n   - 精确匹配 internal_code\n\n3. find_by_product_name(product_name: str) -> list[dict]\n   - 按产品名模糊搜索\n\n返回字段：\n{\n  internal_code: \"...\",\n  product_name: \"...\",\n  product_description: \"...\",\n  export_hs_code: \"...\",\n  customs_name: \"...\",\n  components: \"...\",\n  tax_rebate_rate: 0.13,\n  regulatory_conditions: \"...\"\n}\n\n必须：\n- import openpyxl\n- 懒加载：首次访问时缓存整个 xlsx 到内存字典", {label: "Task4: Export codes service", phase: "Task 1-4: 基础设施层"})

await Promise.all([task1, task2, task3, task4, task5])
log("基础设施层完成：模型 + MSDS + 运输鉴定 + 出口编码")


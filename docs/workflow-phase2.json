phase("Task 7: 前端页面")

const task8 = agent("在 " + FRONTEND_ROOT + "/api/phase2.ts 创建 API 客户端。\n\nexport const phase2Api = {\n  generateBooking(orderId: number) {\n    return axios.get('/documents/booking', { params: { order_id: orderId } })\n  },\n  generateLoi(orderId: number, piNo: string) {\n    return axios.get('/documents/loi', { params: { order_id: orderId, pi_no: piNo } })\n  },\n  generateMsds(product: string) {\n    return axios.get('/documents/msds', { params: { product } })\n  },\n  downloadDocument(docKey: string) {\n    return axios.get('/documents/download/' + docKey, { responseType: 'blob' })\n  },\n  listMsds(params: { page?: number; pageSize?: number; search?: string }) {\n    return axios.get('/msds', { params })\n  },\n  getMsdsContent(id: number) {\n    return axios.get('/msds/' + id + '/content')\n  },\n  reindexMsds() {\n    return axios.post('/msds/reindex')\n  },\n  getTransportReport(file: File) {\n    const formData = new FormData()\n    formData.append('file', file)\n    return axios.post('/transport/upload', formData, { headers: { 'Content-Type': 'multipart/form-data' } })\n  },\n  getExportCodes(internalCode: string) {\n    return axios.get('/export-codes', { params: { internal_code: internalCode } })\n  },\n  getJwt(documentKey: string, userName: string, fileType: string) {\n    return axios.post('/onlyoffice/jwt', null, { params: { documentKey, userName, fileType } })\n  },\n}\n\n从 @/utils/request 导入 axios。", {label: "Task7a: Phase2 API client", phase: "Task 7: 前端页面"})

const task9 = agent("在 " + FRONTEND_ROOT + "/views/phase2/ 创建 Phase2Workflow.vue 主页面。\n\n要求：\n- Vue 3 <script setup> + Element Plus\n- 布局：左侧参考面板（35%宽）+ 右侧 OnlyOffice 编辑器（65%宽），上下排列\n- 顶部工具栏：订单号选择下拉 + PI合同下拉 + 三个按钮 [订舱单] [LOI保函] [MSDS]\n\n顶部工具栏：\n- 订单号下拉：从 /api/v1/merge/orders 加载已合并订单列表，v-model 绑定 selectedOrderId\n- PI合同下拉：根据 selectedOrderId 加载对应的 PI 合同\n- [订舱单] 按钮：点击调用 generateBooking(selectedOrderId)，获取 jwt+downloadUrl，加载到编辑器\n- [LOI保函] 按钮：点击调用 generateLoi(selectedOrderId, selectedPiNo)，加载到编辑器\n- [MSDS] 按钮：弹出 MSDSBrowser 组件选择产品\n\n左侧参考面板（ReferencePanel）：\n- 可折叠的 el-collapse\n- 展开项：Phase1数据 | MSDS摘要 | 运输鉴定 | 出口编码\n- 每个字段旁有复制图标按钮，点击复制到剪贴板\n- Phase1数据 tab 显示：发货人、收货人、通知人、卸货港、商品信息（品名中英文、H.S.Code、毛重、尺码、CBM、桶数、托盘数）\n\n右侧 OnlyOffice 编辑器：\n- 使用 iframe 嵌入 OnlyOffice\n- src = documentServerUrl + \"/apps/documenteditor/main.html?docKey=\" + currentDocKey + \"&token=\" + currentToken\n- 加载中显示 el-skeleton 占位\n\n底部操作栏：\n- [保存] [下载] [打印预览] 按钮\n\n必须：\n- import { phase2Api } from '@/api/phase2'\n- import { useRoute } from 'vue-router'\n- import { ElMessage } from 'element-plus'\n- 从路由 query 获取 orderId 作为初始值\n- 路由：/phase2", {label: "Task7b: Phase2Workflow page", phase: "Task 7: 前端页面"})

const task10 = agent("在 " + FRONTEND_ROOT + "/views/phase2/components/ 创建 ReferencePanel.vue 组件。\n\n要求：\n- Vue 3 <script setup>\n- 可折叠的 el-collapse，4个面板：\n  1. Phase1数据（展示可复制字段）\n  2. MSDS摘要（展示匹配产品的 MSDS 成分表）\n  3. 运输鉴定（上传 PDF 后显示中英文名、报告编号、样品描述）\n  4. 出口编码（输入 internal_code 查询，显示商品编码、报关名称、成分）\n\n每个可复制字段：\n- el-tag 显示字段名 + el-input readonly 显示值 + 复制图标按钮\n- 点击复制：navigator.clipboard.writeText(value)，成功后 ElMessage.success(\"已复制\")\n\nPhase1数据 tab：\n- props: { orderId }\n- 挂载时调用 /api/v1/merge/orders/{orderId}/comparison 获取完整数据\n- 显示：shipper, consignee, notify, port_of_discharge, items(品名/H.S.Code/毛重/尺码/CBM/桶/托盘)\n\nMSDS摘要 tab：\n- props: { productName }\n- 挂载时调用 /api/v1/msds?search={productName}\n- 匹配到则展示：product_name_cn, physical_form, ion_type, ph, composition_summary\n\n运输鉴定 tab：\n- el-upload drag 上传 PDF\n- 上传后调用 /api/v1/transport/upload 解析\n- 展示：品名中英文、报告编号、样品描述\n\n出口编码 tab：\n- props: { internalCode }\n- 输入框 + 查询按钮\n- 调用 /api/v1/export-codes?internal_code={code}\n- 展示：商品编号、商品外观、HS编码、报关名称、成分\n\n必须：\n- import { phase2Api } from '@/api/phase2'\n- import { ElMessage } from 'element-plus'\n- 使用 el-input 的 readonly 属性实现只读显示", {label: "Task7c: ReferencePanel", phase: "Task 7: 前端页面"})


phase("Task 5-6: 核心服务层")

const task6 = agent("在 " + BACKEND_ROOT + "/services/onlyoffice_service.py 创建 OnlyOfficeService 类。\n\nOnlyOfficeService 负责：\n\n1. generate_jwt_token(document_key: str, user_name: str, file_type: str) -> str\n   - 使用 python-jose 的 jwt.encode\n   - Algorithm: HS256\n   - Payload: document{key, title, fileType, callbackUrl}, user{name, id}, editorConfig{callbackUrl, mode}, iat, exp\n   - SECRET_KEY 从环境变量 ONLYOFFICE_SECRET_KEY 获取，默认 \"shipping-helper-secret-key\"\n   - callbackUrl = base_url + \"/api/v1/onlyoffice/callback?doc_key=\" + document_key\n\n2. build_editor_config(token: str, document_key: str, doc_type: str) -> dict\n   - 返回 OnlyOffice DocumentServer 配置对象\n   - documentServerUrl 从环境变量 DOCUMENT_SERVER_URL 获取，默认 \"http://localhost:8080\"\n   - 返回 {token, documentServerUrl, documentKey, docType}\n\n必须：\n- from jose import jwt\n- from datetime import datetime, timedelta\n- import os\n\n然后在 " + BACKEND_ROOT + "/api/v1/onlyoffice.py 创建路由：\n\nPOST /api/v1/onlyoffice/jwt\n  Body: documentKey, userName, fileType (form data)\n  Response: {token, documentServerUrl, documentKey, docType}\n\nPOST /api/v1/onlyoffice/callback\n  Query: doc_key: str\n  Form: file: UploadFile (字段名 \"content\")\n  Response: {\"error\": 0}\n  逻辑：\n  1. 读取 file.content 写入 data/docs/{doc_key}.bin\n  2. 返回 {\"error\": 0}\n\nGET /api/v1/onlyoffice/download/{doc_key}\n  Response: FileResponse 从 data/docs/{doc_key}.bin", {label: "Task5: OnlyOffice service", phase: "Task 5-6: 核心服务层"})

const task7 = agent("在 " + BACKEND_ROOT + "/services/document_service.py 创建 DocumentService 类。\n\nDocumentService 负责生成三种文档：\n\n1. generate_booking(order_id: int, db_session) -> tuple[bytes, str]\n   - 读取模板：" + PHASE2_ROOT + "/参考/02.订舱出货/长晟出口海运BOOKING模板.xls\n   - 从数据库加载 order + order_items + pi_contract 数据\n   - 用 xlwt 写入 .xls：\n     * 发货人（Shipper）：HONGHAO CHEMICAL CO., LTD. + 地址\n     * 收货人（Consignee）：PI consignee name + address\n     * 通知人（Notify）：同 consignee\n     * 卸货港（Port of Discharge）：PI destination\n     * 商品表格：品名（product_cn + product_en）、毛重(gross_weight_kg)、尺码(volume_cbm)\n   - 返回 (bytes, doc_key)\n   - doc_key = f\"booking_{order_id}_{timestamp}\"\n\n2. generate_loi(order_id: int, pi_no: str, db_session) -> tuple[bytes, str]\n   - 读取模板：" + PHASE2_ROOT + "/参考/02.订舱出货/源文件/LOI-op-非危险品保函模板.docx\n   - 用 python-docx 读取，找到所有段落，替换占位符：\n     * {{shipper}} -> HONGHAO CHEMICAL CO., LTD.\n     * {{consignee}} -> PI consignee name\n     * {{consignee_address}} -> PI consignee address\n     * {{port_of_discharge}} -> PI destination\n     * {{product_name_cn}} -> order item product_cn\n     * {{product_name_en}} -> order item product_en\n     * {{hs_code}} -> order item hs_code\n     * {{gross_weight}} -> total gross weight\n     * {{volume}} -> total volume CBM\n     * {{date}} -> current date\n   - 返回 (bytes, doc_key)\n   - doc_key = f\"loi_{order_id}_{timestamp}\"\n\n3. generate_msds(product_name: str, db_session) -> tuple[bytes, str]\n   - 从 MSDSService 查找匹配的 MSDS 文件\n   - 提取完整内容（composition table + physical props）\n   - 生成新的 .docx 文档（python-docx）\n   - 返回 (bytes, doc_key)\n\n必须：\n- import xlwt\n- from docx import Document\n- from docx.shared import Pt, Inches\n- from app.services.msds_service import MSDSService\n- from app.services.calculation_service import CalculationService\n- 模板文件不存在时抛 FileNotFoundError\n\n在 " + BACKEND_ROOT + "/api/v1/documents.py 创建路由：\n\nGET /api/v1/documents/booking?order_id=int\n  Response: {downloadUrl, jwtToken, docKey, docType: \"xls\"}\n\nGET /api/v1/documents/loi?order_id=int&pi_no=str\n  Response: {downloadUrl, jwtToken, docKey, docType: \"docx\"}\n\nGET /api/v1/documents/msds?product=str\n  Response: {downloadUrl, jwtToken, docKey, docType: \"docx\"}\n\nGET /api/v1/documents/download/{doc_key}\n  Response: FileResponse", {label: "Task6: Document service", phase: "Task 5-6: 核心服务层"})

await Promise.all([task6, task7])
log("核心服务层完成：OnlyOffice + Document 生成")

